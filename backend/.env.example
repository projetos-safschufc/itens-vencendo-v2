# Copie para .env e preencha. Nunca commite .env nem .env.password.
# Credenciais: use aspas duplas em valores com espaços ou #. Não use espaço após =.
#
# Senhas (estratégia recomendada – arquivos separados):
#   Deixe DB_PASSWORD e AUTH_DB_PASSWORD vazios aqui e use .env.password (no .gitignore).
#   Opcional: DB_PASSWORD_FILE=caminho/para/arquivo (padrão: .env.password)
#
# Formato .env.password:
#   DB_PASSWORD=abi123!@#qwe
#   AUTH_DB_PASSWORD=abi123!@#qwe
#   (linhas com # no início são comentários; sem aspas no valor)
#
APP_NAME=Inventory Analytics API
DEBUG=false
ENVIRONMENT=development

DB_HOST=pgpool1.ebserh
DB_PORT=5432
DB_NAME=powerbi
DB_USER=Abimael
DB_PASSWORD=
DB_SCHEMA=gad_dlih_safs

# Banco SAFS (auth – ctrl.users). Login falha com 503 se não conectar.
# Confira: mesmo host/porta do powerbi ou outro? Rede/VPN e .env.password com AUTH_DB_PASSWORD.
AUTH_DB_HOST=pgpool1.ebserh
AUTH_DB_PORT=5433
AUTH_DB_NAME=safs
AUTH_DB_USER=abimael
AUTH_DB_PASSWORD=
AUTH_DB_SCHEMA=ctrl

JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Bcrypt: 10 = login mais rápido (~100ms); 12 = mais seguro (~300ms)
BCRYPT_ROUNDS=10

CACHE_TTL_SECONDS=60

# CORS: inclua a URL do frontend para acesso pela rede (servidor 10.28.0.124).
# Outros usuários acessando http://10.28.0.124:5173 precisam dessas origens.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://10.28.0.124:5173","http://10.28.0.124:3000","http://10.28.0.124","http://10.28.0.124:80"]
