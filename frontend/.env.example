# Copie para .env e ajuste conforme o ambiente.
# Não commite o arquivo .env.
#
# URL da API (backend). Em desenvolvimento com proxy (vite.config.ts) pode ficar vazio ou /api.
# No servidor (ex.: 10.28.0.124): use a URL completa para outros usuários acessarem.
# Exemplo servidor: outros usuários abrem http://10.28.0.124:5173 e o frontend chama a API em :8000.
VITE_API_URL=http://10.28.0.124:8000
